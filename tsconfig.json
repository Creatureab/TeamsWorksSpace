{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@editor": ["./packages/editor/src/index.ts"],
      "@editor/*": ["./packages/editor/src/*"],
      "@models": ["./packages/models/src/index.ts"],
      "@models/*": ["./packages/models/src/*"],
      "@utils": ["./packages/utils/src/index.ts"],
      "@utils/*": ["./packages/utils/src/*"],
      "@config": ["./packages/config"],
      "@config/*": ["./packages/config/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
